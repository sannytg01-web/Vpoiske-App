# ──────────────────────────────────────────────
#  Vlubvi — .env.example
#  Скопируйте в .env и заполните реальными значениями
# ──────────────────────────────────────────────

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://vlubvi:changeme@pgbouncer:5432/vlubvi
POSTGRES_PASSWORD=changeme

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── Encryption (Fernet 32-byte base64) ───
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=YOUR_FERNET_KEY_HERE

# ─── JWT RS256 Keys ───
# Генерация: openssl genrsa -out jwt_private.pem 2048
#             openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Затем вставить содержимое файлов ниже (без переносов строк, заменяя \n)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ─── Telegram Bot ───
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ─── MAX (max.ru) ───
MAX_SECRET_KEY=your_max_secret_key_here

# ─── Yandex Cloud (LLM / GPT) ───
YANDEX_API_KEY=your_yandex_api_key
YANDEX_FOLDER_ID=b1g000000000000000

# ─── T-Bank (Tinkoff) Payments ───
TBANK_TERMINAL_KEY=your_terminal_key
TBANK_PASSWORD=your_password

# ─── SMS.RU ───
SMS_RU_API_KEY=your_sms_ru_api_key

# ─── Sentry ───
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── LLM Settings ───
LLM_MAX_CONCURRENT=50
LLM_TEMPERATURE=0.72
LLM_MAX_TOKENS=500
